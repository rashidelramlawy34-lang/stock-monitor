# Anthropic API — required for AI Advisor feature
ANTHROPIC_API_KEY=sk-ant-...

# Server config
PORT=3001
NODE_ENV=development

# SQLite database path (relative to server/)
DB_PATH=../db/portfolio.db

# Price refresh interval in milliseconds (default: 30 seconds)
PRICE_REFRESH_INTERVAL=30000

# Finnhub — required for live prices and news (free at finnhub.io, 60 req/min)
FINNHUB_API_KEY=your_key_here
